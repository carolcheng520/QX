# PURPOSE: MITM rules to block Tencent Sports splash, feed, article, widget, and VIP popup ads.
# LINK: https://raw.githubusercontent.com/carolcheng520/anyrule/main/mitm/TencentSportsAdBlock.amrs
# SOURCE: https://raw.githubusercontent.com/Hey-sayiwanna/TencentSports-Surge/main/TencentSportsAdBlock.sgmodule
# LAST-UPDATED: 2026-06-29
# SUGGESTED-ACTION: Enable MITM
# RULES: 7
# COMPANION-FILES: None; the upstream module has no routing-layer REJECT rules, only MITM local responses and response rewrites.

name = Tencent Sports Ad Block
hostname = app.sports.qq.com, config.ab.qq.com, shequ.sports.qq.com, film.video.qq.com

0, 100, ^https://config\.ab\.qq\.com/tab/GetTabRemoteConfig.*, ZnVuY3Rpb24gcHJvY2VzcyhjdHgpIHsKICBBbnl3aGVyZS5yZXNwb25kKHsKICAgIHN0YXR1czogMjAwLAogICAgaGVhZGVyczogW1siQ29udGVudC1UeXBlIiwgImFwcGxpY2F0aW9uL3Byb3RvIl1dLAogICAgYm9keTogIiIKICB9KTsKfQo=
0, 100, ^https://config\.ab\.qq\.com/tab/GetTabToggle.*, ZnVuY3Rpb24gcHJvY2VzcyhjdHgpIHsKICBBbnl3aGVyZS5yZXNwb25kKHsKICAgIHN0YXR1czogMjAwLAogICAgaGVhZGVyczogW1siQ29udGVudC1UeXBlIiwgImFwcGxpY2F0aW9uL3Byb3RvIl1dLAogICAgYm9keTogIiIKICB9KTsKfQo=
1, 100, ^https://app\.sports\.qq\.com/(?:feeds/list|m/matchAfter/stats|match/adBanner)\?, 
1, 100, ^https://shequ\.sports\.qq\.com/topic/detail\?, 
1, 100, ^https://app\.sports\.qq\.com/trpc\.sports_resource\.cgi\.ResourceCGI/MatchWidgets(?:\?.*)?$, 
1, 100, ^https://app\.sports\.qq\.com/vaccess/trpc\.sports_resource\.cgi\.ResourceCGI/ColumnWidget(?:\?.*)?$, 
